# ==============================================================================
# AI Unit Website — environment configuration
# ==============================================================================
# Copy this file to .env and fill in real values for your machine:
#
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed — only this .env.example is.
# It's loaded automatically on every request by bootstrap.php via
# vlucas/phpdotenv. Every value below also has a safe fallback baked into
# config/config.php and config/database.php, so the site still runs even
# without a .env file at all — but a real database connection needs the
# DATABASE_* values below to match your MySQL setup.

# ------------------------------------------------------------------------------
# Application (config/config.php)
# ------------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true

# Leave both blank to auto-detect from the request. Only set these if the
# site is reachable at a different URL than the one it auto-detects (e.g.
# behind a reverse proxy).
APP_BASE_URL=
APP_ROOT_URL=

# ------------------------------------------------------------------------------
# Database (config/database.php) — values shown match a stock XAMPP/EasyPHP
# MySQL install (root user, no password, default port).
# ------------------------------------------------------------------------------
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# ------------------------------------------------------------------------------
# Contact form notifications (App\Services\EmailService)
# ------------------------------------------------------------------------------
EMAIL_ENABLED=false

CONTACT_EMAIL=aiunit@govmu.org

MAIL_FROM_ADDRESS=no-reply@aiunit.govmu.org
MAIL_FROM_NAME="AI Unit"

# SMTP_HOST/USERNAME/PASSWORD are required only once EMAIL_ENABLED=true —
# your real mail provider's SMTP server and mailbox credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls

# ------------------------------------------------------------------------------
# Contact form spam guard (App\Services\SpamGuard) — all optional
# ------------------------------------------------------------------------------
CONTACT_MIN_SUBMIT_SECONDS=3
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW=600

# ------------------------------------------------------------------------------
# Future DIVA API integration (not implemented yet)
# ------------------------------------------------------------------------------
DIVA_API_URL=http://127.0.0.1:8000/api/chat
