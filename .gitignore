# Videos
*.mp4

# Audio
*.mp3

# Documents
*.pdf

# Subtitles / captions
*.vtt

# Python / backend
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/

# Environment configuration (config/config.php, config/database.php — see
# .env.example). Contains real credentials once filled in, so it must never
# be committed; .env.example (the template) IS tracked.
.env

# Composer dependencies (currently just PHPMailer, for SMTP mail sending).
# composer.json and composer.lock ARE tracked — run `composer install` to
# regenerate this folder.
vendor/

# Runtime storage & user uploads (keep the folders, ignore their contents)
storage/logs/*
storage/cache/*
!storage/logs/.gitkeep
!storage/cache/.gitkeep
uploads/*
!uploads/.gitkeep